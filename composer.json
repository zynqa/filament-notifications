{
    "name": "zynqa/filament-notifications",
    "description": "Admin notification management system for FilamentPHP",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Zynqa",
            "email": "info@zynqa.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.2",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/support": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Zynqa\\FilamentNotifications\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zynqa\\FilamentNotifications\\FilamentNotificationsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
